# TwistStick clangd configuration
# Optimized for ESP32/PlatformIO development

CompileFlags:
  # Use compile_commands.json generated by PlatformIO
  CompilationDatabase: .

  # Additional flags for better ESP32 support
  Add:
    - -ferror-limit=0
    - -Wno-unknown-warning-option

  Remove:
    # Remove GCC-specific flags that clang doesn't understand
    - -mlongcalls
    - -fno-rtti
    - -fstrict-volatile-bitfields
    - -ffunction-sections
    - -fdata-sections
    - -Wno-frame-address
    - -mtext-section-literals
    - -fno-tree-switch-conversion
    - -freorder-blocks

Index:
  Background: Build

Diagnostics:
  # Enable clang-tidy integration
  ClangTidy:
    Add:
      - bugprone-*
      - modernize-*
      - readability-*
      - performance-*
    Remove:
      - modernize-use-trailing-return-type
      - readability-identifier-length
      - readability-magic-numbers

  # Suppress some noisy warnings from system headers
  Suppress:
    - pp_including_mainfile_in_preamble
    - drv_unknown_argument

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true
  Designators: true

Hover:
  ShowAKA: true
